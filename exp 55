<!DOCTYPE html>
<html>
<head>
    <title>AJAX Search Suggestion</title>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <style>
        #suggestions{
            border:1px solid #ccc;
            max-width:300px;
            display:none;
            position:absolute;
            background:white;
        }

        #suggestions div{
            padding:8px;
            cursor:pointer;
        }

        #suggestions div:hover{
            background:#f0f0f0;
        }
    </style>
</head>

<body>

<input type="text" id="search" placeholder="Search..." autocomplete="off">
<div id="suggestions"></div>

</body>
</html>
